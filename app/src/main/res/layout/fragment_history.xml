<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Historial de Boletos Emitidos"
        android:textSize="22sp"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvResumenCuadre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F0F4C3"
        android:padding="12dp"
        android:text="Calculando cuadre de caja..."
        android:textColor="#33691E"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mantén presionado un boleto para anularlo"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBoletos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical" />

    <Button
        android:id="@+id/btnCerrarTurno"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="LIQUIDAR Y CERRAR TURNO"
        android:backgroundTint="@color/accent"
        android:textColor="@color/white"
        android:textStyle="bold" />
    <Button
        android:id="@+id/btnSincronizarParcial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#1E3A8A"
        android:text="🔄 Sincronizar Boletos en Ruta"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_margin="8dp"/>
</LinearLayout>